{
  "Paths": {
    "train_script": "train/train_step.py",
    "train_manifest": "data_pipeline/artifacts/phase1/manifest.json",
    "eval_manifest": "data_pipeline/artifacts/phase1_eval/manifest.json",
    "checkpoint_dir": "train/checkpoints_phase1_52l_bulk",
    "run_log": "train/pretrain_phase1_52l_bulk.jsonl",
    "resume_from": null
  },
  "Hardware_Profile": {
    "device": "cuda",
    "precision": "bf16",
    "data_workers": 4,
    "prefetch_factor": 4,
    "persistent_workers": true,
    "prefetch_to_device": true
  },
  "Model_Architecture": {
    "vocab_size": 32000,
    "d_model": 3072,
    "n_layers": 52,
    "n_heads": 24,
    "n_kv_heads": 8,
    "max_seq_len": 8192,
    "dropout": 0.0,
    "ffn_dim": 2048,
    "ffn_kind": "swiglu",
    "reasoning_start_layer": 20,
    "reasoning_ffn_dim": 2048,
    "reasoning_ffn_kind": "swiglu",
    "ffn_multiple_of": 256,
    "gqa_layers": 12,
    "lightning_end_layer": 36,
    "mla_latent_dim": 768,
    "cognitive_loops": 5,
    "cognitive_num_experts": 8,
    "cognitive_num_groups": 1,
    "cognitive_groups_top_k": 1,
    "cognitive_top_k": 2,
    "cognitive_gate_type": "sigmoid",
    "cognitive_aux_alpha": 0.01,
    "cognitive_entropy_alpha": 0.001,
    "cognitive_ffn_kind": "swiglu",
    "cognitive_ffn_dim": 2048
  },
  "Training_Hyperparams": {
    "total_steps": 50000,
    "chunk_steps": 1000,
    "save_every": 500,
    "log_every": 20,
    "eval_every": 500,
    "eval_batches": 25,
    "eval_batch_size": 1,
    "optimizer": "muon",
    "micro_batch_size": 1,
    "grad_accum_steps": 16,
    "lr": 0.00025,
    "warmup_steps": 1500,
    "min_lr_ratio": 0.1,
    "weight_decay": 0.01,
    "clip_grad_norm": 1.0,
    "seed": 42,
    "checkpoint_keep_last": 5,
    "freeze_layers_below": 0,
    "freeze_embeddings": false,
    "freeze_final_norm": false,
    "freeze_cognitive_block": false,
    "resume_model_only": false
  },
  "Telemetry_Alerts": {
    "log_router_stats_every": 20,
    "collapse_cv_threshold": 0.5,
    "collapse_entropy_threshold": 0.25,
    "adaptive_aux_alpha": true,
    "aux_alpha_max": 0.2,
    "aux_alpha_up_mult": 1.5,
    "aux_alpha_decay": 0.95,
    "early_stop_usage_cv_threshold": 0.85,
    "early_stop_usage_cv_patience": 5,
    "stop_on_nan_eval_perplexity": true
  }
}
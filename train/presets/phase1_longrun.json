{
  "Paths": {
    "train_script": "train/train_step.py",
    "train_manifest": "data_pipeline/artifacts/phase1/manifest.json",
    "eval_manifest": "data_pipeline/artifacts/phase1_eval/manifest.json",
    "checkpoint_dir": "train/checkpoints_phase1",
    "run_log": "train/pretrain_phase1_run.jsonl",
    "resume_from": null
  },
  "Hardware_Profile": {
    "device": "cuda",
    "precision": "bf16",
    "data_workers": 4,
    "prefetch_factor": 4,
    "persistent_workers": true,
    "prefetch_to_device": true
  },
  "Model_Architecture": {
    "vocab_size": 32000,
    "d_model": 2048,
    "n_layers": 24,
    "n_heads": 16,
    "n_kv_heads": 4,
    "max_seq_len": 8192,
    "dropout": 0.0,
    "ffn_multiple_of": 256,
    "cognitive_loops": 5,
    "cognitive_num_experts": 8,
    "cognitive_top_k": 4,
    "cognitive_gate_type": "sigmoid",
    "cognitive_aux_alpha": 0.01,
    "cognitive_entropy_alpha": 0.001
  },
  "Training_Hyperparams": {
    "total_steps": 50000,
    "chunk_steps": 1000,
    "save_every": 500,
    "log_every": 20,
    "eval_every": 500,
    "eval_batches": 50,
    "eval_batch_size": 2,
    "optimizer": "muon",
    "micro_batch_size": 2,
    "grad_accum_steps": 8,
    "lr": 0.0003,
    "warmup_steps": 1500,
    "min_lr_ratio": 0.1,
    "weight_decay": 0.01,
    "clip_grad_norm": 1.0,
    "seed": 42,
    "checkpoint_keep_last": 5
  },
  "Telemetry_Alerts": {
    "log_router_stats_every": 20,
    "collapse_cv_threshold": 0.5,
    "collapse_entropy_threshold": 0.25,
    "adaptive_aux_alpha": true,
    "aux_alpha_max": 0.2,
    "aux_alpha_up_mult": 1.5,
    "aux_alpha_decay": 0.95,
    "early_stop_usage_cv_threshold": 0.85,
    "early_stop_usage_cv_patience": 5,
    "stop_on_nan_eval_perplexity": true
  }
}
